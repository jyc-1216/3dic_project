# ============================================================
# Lower-die Synopsys Design Compiler synthesis flow
# ============================================================

set script_dir  [file dirname [file normalize [info script]]]
set project_dir [file dirname $script_dir]

set generated_dir ${project_dir}/generated
set report_dir    ${project_dir}/reports/dc_lower
set import_tcl    ${generated_dir}/lower_die_dc_import.tcl

foreach required_var {DC_TARGET_LIBRARY DC_LINK_LIBRARY} {
    if {![info exists env($required_var)]} {
        error "Environment variable is not set: $required_var"
    }
}

if {![file exists $import_tcl]} {
    error "Tessent DC import script does not exist: $import_tcl"
}

file mkdir $generated_dir
file mkdir $report_dir

set target_library [split $env(DC_TARGET_LIBRARY) ":"]
set link_library   [concat "*" [split $env(DC_LINK_LIBRARY) ":"]]

if {[info exists env(DC_SEARCH_PATH)] && $env(DC_SEARCH_PATH) ne ""} {
    set search_path [concat $search_path [split $env(DC_SEARCH_PATH) ":"]]
}

# Load the post-DFT design using the script generated by Tessent.
source $import_tcl

current_design lower_die_top
link
uniquify

# TCK is the only sequential clock in this lower-die demonstration.
create_clock -name TCK -period 100 [get_ports tck]
set_clock_uncertainty 1.0 [get_clocks TCK]

redirect -file ${report_dir}/check_design_precompile.rpt {
    check_design
}

# Preserve the inserted IJTAG hierarchy during the first bring-up.
compile_ultra -no_autoungroup

redirect -file ${report_dir}/qor.rpt {
    report_qor
}
redirect -file ${report_dir}/area.rpt {
    report_area -hierarchy
}
redirect -file ${report_dir}/timing.rpt {
    report_timing -max_paths 20
}
redirect -file ${report_dir}/check_design_postcompile.rpt {
    check_design
}

# Use stable Verilog-compatible names for the gate-level handoff.
change_names -rules verilog -hierarchy

write -format verilog -hierarchy \
    -output ${generated_dir}/lower_die_ijtag_synthesized.v
write -format ddc -hierarchy \
    -output ${generated_dir}/lower_die_ijtag_synthesized.ddc
write_sdc ${generated_dir}/lower_die_ijtag_synthesized.sdc

puts "Lower-die DC synthesis completed"
quit
